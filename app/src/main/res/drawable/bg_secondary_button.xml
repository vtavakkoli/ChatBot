<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#ECE6F0" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="#D0C8D8" />
            <padding android:left="16dp" android:right="16dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
    <item>
        <shape>
            <solid android:color="@color/primary_light" />
            <corners android:radius="28dp" />
            <stroke android:width="1dp" android:color="@color/outline_soft" />
            <padding android:left="16dp" android:right="16dp" android:top="10dp" android:bottom="10dp" />
        </shape>
    </item>
</selector>
